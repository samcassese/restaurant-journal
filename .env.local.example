# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used in API routes / server actions. Never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google APIs (Cloud Console: APIs & Services)
# Enable: Places API, Maps JavaScript API, Geocoding API
GOOGLE_PLACES_API_KEY=your-google-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-js-key
